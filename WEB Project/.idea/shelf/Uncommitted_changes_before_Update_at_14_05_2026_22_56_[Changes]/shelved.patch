+{% extends "base.html" %}
+
+{% block content %}
+<h1>Публикация продукта</h1>
+<div>
+    <form class="login_form" method="POST" enctype="multipart/form-data">
+        {{ form.hidden_tag() }}
+        {{ form.name(class="form-control", placeholder="Введите имя*") }}
+        {% for error in form.name.errors %}
+            <p class="text-danger">{{ error }}</p>
+        {% endfor %}
+        <br>
+        <div class="form-group">
+            {{ form.about.label }}
+            {{ form.about(class="form-control", placeholder="...", rows="3") }}
+            {% for error in form.about.errors %}
+                <p class="text-danger">{{ error }}</p>
+            {% endfor %}
+        </div>
+        <br>
+        <div class="form-group">
+            {{ form.photo.label }}
+            {{ form.photo(class="form-control-file", required=True, accept="image/*") }}
+            {% for error in form.photo.errors %}
+                <p class="text-danger">{{ error }}</p>
+            {% endfor %}
+        </div>
+        <br>
+        <label>Добавьте контактную информацию</label>
+        {{ form.email(class="form-control", placeholder="Введите адрес электронной почты*") }}
+        {% for error in form.email.errors %}
+            <p class="text-danger">{{ error }}</p>
+        {% endfor %}
+        {{ form.phone_number(class="form-control", placeholder="Введите номер телефона") }}
+        {% for error in form.phone_number.errors %}
+            <p class="text-danger">{{ error }}</p>
+        {% endfor %}
+        <br>
+        {{ form.submit(class="btn btn-primary") }}
+    </form>
+</div>
+{% endblock %}
